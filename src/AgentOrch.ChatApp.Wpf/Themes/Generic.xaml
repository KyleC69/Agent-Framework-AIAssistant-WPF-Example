<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:AgentOrch.ChatApp.Wpf.Controls">


    <Style TargetType="{x:Type controls:AIToolUsageIndicators}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:AIToolUsageIndicators}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ItemsControl
                            ItemsSource="{Binding Indicators, RelativeSource={RelativeSource TemplatedParent}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Vertical" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Ellipse
                                        Width="{Binding IndicatorSize, RelativeSource={RelativeSource AncestorType={x:Type controls:AIToolUsageIndicators}}}"
                                        Height="{Binding IndicatorSize, RelativeSource={RelativeSource AncestorType={x:Type controls:AIToolUsageIndicators}}}"
                                        Margin="0,6"
                                        StrokeThickness="0">
                                        <Ellipse.RenderTransform>
                                            <ScaleTransform ScaleX="1" ScaleY="1" CenterX="0.5" CenterY="0.5" />
                                        </Ellipse.RenderTransform>
                                        <Ellipse.Style>
                                            <Style TargetType="{x:Type Ellipse}">
                                                <Setter Property="Fill"
                                                        Value="{Binding OffBrush, RelativeSource={RelativeSource AncestorType={x:Type controls:AIToolUsageIndicators}}}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsOn}" Value="True">
                                                        <Setter Property="Fill"
                                                                Value="{Binding OnBrush, RelativeSource={RelativeSource AncestorType={x:Type controls:AIToolUsageIndicators}}}" />
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation
                                                                        Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                        To="1.05" Duration="0:0:0.12"
                                                                        AutoReverse="True" />
                                                                    <DoubleAnimation
                                                                        Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                        To="1.05" Duration="0:0:0.12"
                                                                        AutoReverse="True" />
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.EnterActions>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>