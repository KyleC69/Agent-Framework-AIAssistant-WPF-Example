<Application x:Class="AgentOrchestration.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="App.WindowBackgroundColor">Bisque</Color>  <!--User text box background -->
            <Color x:Key="App.SurfaceColor">#111133</Color>
            <Color x:Key="App.ControlSurfaceColor">#FF2D2D30</Color>
            <Color x:Key="App.AccentColor">#FF512BD4</Color>
            <Color x:Key="App.TextPrimaryColor">Black</Color>
            <Color x:Key="App.HeaderTextPrimaryColor">White</Color>
            <Color x:Key="App.TextSecondaryColor">#EE66FFFF</Color>
            <Color x:Key="App.ListForegroundColor">#FFF9EDED</Color>
            <Color x:Key="App.CodeBlockBackGroundColor">DarkGray</Color>
            <Color x:Key="App.CodeBlockForegroundColor">Black</Color>


            <SolidColorBrush x:Key="UserBubbleBrush" Color="{DynamicResource App.AccentColor}" />
            <SolidColorBrush x:Key="AgentBubbleBrush" Color="{DynamicResource App.BubbleAgentColor}" />
            <SolidColorBrush x:Key="SystemBubbleBrush" Color="{DynamicResource App.BubbleSystemColor}" />
            <SolidColorBrush x:Key="BubbleForegroundBrush" Color="{DynamicResource App.BubbleForegroundColor}" />
            <SolidColorBrush x:Key="CodeBubbleBackgroundBrush" Color="{DynamicResource App.CodeBlockBackGroundColor}" />
            <SolidColorBrush x:Key="CodeBubbleForegroundBrush" Color="{DynamicResource App.CodeBlockForegroundColor}" />

            <Color x:Key="App.BubbleAgentColor">#A09F9E</Color>
            <Color x:Key="App.BubbleSystemColor">#AA323A11</Color>
            <Color x:Key="App.BubbleForegroundColor">DarkBlue</Color>


            <Style x:Key="AgentsOptionsStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="TextWrapping" Value="NoWrap" />
                <Setter Property="TextTrimming" Value="None" />
            </Style>

            <SolidColorBrush x:Key="App.WindowBackgroundBrush" Color="{StaticResource App.WindowBackgroundColor}" />
            <SolidColorBrush x:Key="App.SurfaceBrush" Color="{StaticResource App.SurfaceColor}" />
            <SolidColorBrush x:Key="App.ControlSurfaceBrush" Color="{StaticResource App.ControlSurfaceColor}" />
            <SolidColorBrush x:Key="App.AccentBrush" Color="{StaticResource App.AccentColor}" />
            <SolidColorBrush x:Key="App.TextPrimaryBrush" Color="{StaticResource App.TextPrimaryColor}" />
            <SolidColorBrush x:Key="App.TextSecondaryBrush" Color="{StaticResource App.TextSecondaryColor}" />
            <SolidColorBrush x:Key="App.ListForegroundBrush" Color="{StaticResource App.ListForegroundColor}" />
            <SolidColorBrush x:Key="App.BubbleAgentBrush" Color="{StaticResource App.BubbleAgentColor}" />
            <SolidColorBrush x:Key="App.BubbleSystemBrush" Color="{StaticResource App.BubbleSystemColor}" />
            <SolidColorBrush x:Key="App.BubbleForegroundBrush" Color="{StaticResource App.BubbleForegroundColor}" />

            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Markdig.Wpf;component/Themes/Generic.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Wpf.Ui;component/Controls/Button/Button.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>