<UserControl x:Class="AgentOrchestration.Wpf.Controls.AgentControls"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:AgentOrchestration.Wpf.Controls"

             mc:Ignorable="d" Width="250" Height="600"
             d:DesignHeight="600" d:DesignWidth="250" Background="{DynamicResource App.AccentBrush}"
             BorderBrush="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}">

    <Grid x:Name="AiAgentOptions">
        <TextBlock Style="{DynamicResource AgentsOptionsStyle}" HorizontalAlignment="Left" Margin="71,17,0,0"
                   TextWrapping="Wrap" Text="AI Agent Options" VerticalAlignment="Top">
            <TextBlock.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Black" />
                    <GradientStop Color="#FFD06363" Offset="1" />
                    <GradientStop Color="#83DE7070" Offset="0.44" />
                </LinearGradientBrush>
            </TextBlock.Background>
        </TextBlock>
        <TextBlock HorizontalAlignment="Left" Margin="18,60,0,0" TextWrapping="Wrap" Text="Agents"
                   VerticalAlignment="Top">
            <TextBlock.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Black" />
                    <GradientStop Color="#FFD06363" Offset="1" />
                    <GradientStop Color="#83DE7070" Offset="0.44" />
                </LinearGradientBrush>
            </TextBlock.Background>
        </TextBlock>
        <CheckBox x:Name="cb1" Style="{DynamicResource AgentOptionTextBoxStyle}" Content="Single"
                  HorizontalAlignment="Left" Margin="18,92,0,0" VerticalAlignment="Top" Width="178" Height="20">
            <CheckBox.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Black" />
                    <GradientStop Color="#FFD06363" Offset="1" />
                    <GradientStop Color="#83DE7070" Offset="0.44" />
                </LinearGradientBrush>
            </CheckBox.Background>
        </CheckBox>
        <CheckBox x:Name="cb2" Style="{DynamicResource AgentOptionTextBoxStyle}" Content="Two"
                  HorizontalAlignment="Left" Margin="18,112,0,0" VerticalAlignment="Top"
                  ToolTip="Four agents in a hand off scenario, One orchestrator, three workers" Width="178" Height="20">
            <CheckBox.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Black" />
                    <GradientStop Color="#FFD06363" Offset="1" />
                    <GradientStop Color="#83DE7070" Offset="0.44" />
                </LinearGradientBrush>
            </CheckBox.Background>
        </CheckBox>
        <CheckBox Style="{DynamicResource AgentOptionTextBoxStyle}" Content="Three" HorizontalAlignment="Left"
                  Margin="18,132,0,0" VerticalAlignment="Top" Width="178" Height="20">
            <CheckBox.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Black" />
                    <GradientStop Color="#FFD06363" Offset="1" />
                    <GradientStop Color="#83DE7070" Offset="0.44" />
                </LinearGradientBrush>
            </CheckBox.Background>
        </CheckBox>
        <Slider x:Name="PanelWidth" HorizontalAlignment="Left" Margin="18,295,0,0" VerticalAlignment="Top" Width="120"
                BorderThickness="2,2,2,2">
            <Slider.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Black" Offset="0.05" />
                    <GradientStop Color="#FF707070" Offset="0.06" />
                    <GradientStop Color="Black" Offset="0.07" />
                    <GradientStop Color="#FFB4274D" Offset="0.08" />
                </LinearGradientBrush>
            </Slider.Background>
        </Slider>
        <TextBlock HorizontalAlignment="Left" Margin="18,274,0,0" TextWrapping="Wrap" Text="Panel Width"
                   VerticalAlignment="Top">
            <TextBlock.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Black" />
                    <GradientStop Color="#FFD06363" Offset="1" />
                    <GradientStop Color="#83DE7070" Offset="0.44" />
                </LinearGradientBrush>
            </TextBlock.Background>
        </TextBlock>
        <Slider HorizontalAlignment="Left" Margin="22,387,0,0" VerticalAlignment="Top" Width="120"
                RenderTransformOrigin="0.5,0.5">
            <Slider.RenderTransform>
                <TransformGroup>
                    <ScaleTransform />
                    <SkewTransform />
                    <RotateTransform Angle="90.481" />
                    <TranslateTransform />
                </TransformGroup>
            </Slider.RenderTransform>
            <Slider.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Black" Offset="0.05" />
                    <GradientStop Color="#FF707070" Offset="0.06" />
                    <GradientStop Color="Black" Offset="0.07" />
                    <GradientStop Color="#FFB4274D" Offset="0.08" />
                </LinearGradientBrush>
            </Slider.Background>
        </Slider>
        <CheckBox x:Name="cb4" Style="{DynamicResource AgentOptionTextBoxStyle}" Content="Four"
                  HorizontalAlignment="Left" Margin="18,152,0,0" VerticalAlignment="Top" Width="178" Height="20">
            <CheckBox.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Black" />
                    <GradientStop Color="#FFD06363" Offset="1" />
                    <GradientStop Color="#83DE7070" Offset="0.44" />
                </LinearGradientBrush>
            </CheckBox.Background>
        </CheckBox>
        <TextBox x:Name="Agent1ID" HorizontalAlignment="Left" Height="20" Margin="91,90,0,0" TextWrapping="Wrap"
                 Text="TextBox" VerticalAlignment="Top" Width="137" Foreground="#FFFFEBEB">
            <TextBox.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Black" />
                    <GradientStop Color="#FFDC9090" Offset="1" />
                </LinearGradientBrush>
            </TextBox.Background>
        </TextBox>
        <CheckBox x:Name="cb3" Style="{DynamicResource AgentOptionTextBoxStyle}" Content="Three"
                  HorizontalAlignment="Left" Margin="18,132,0,0" VerticalAlignment="Top" Width="178" Height="20">
            <CheckBox.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Black" />
                    <GradientStop Color="#FFD06363" Offset="1" />
                    <GradientStop Color="#83DE7070" Offset="0.44" />
                </LinearGradientBrush>
            </CheckBox.Background>
        </CheckBox>
        <TextBox x:Name="Agent4Name" HorizontalAlignment="Left" Height="20" TextWrapping="Wrap" Text="TextBox"
                 VerticalAlignment="Top" Width="137" Foreground="#FFFFEBEB" Margin="92,151,0,0">
            <TextBox.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Black" />
                    <GradientStop Color="#FFDC9090" Offset="1" />
                </LinearGradientBrush>
            </TextBox.Background>
        </TextBox>
        <TextBox x:Name="Agent3Name" HorizontalAlignment="Left" Height="20" Margin="92,129,0,0" TextWrapping="Wrap"
                 Text="TextBox" VerticalAlignment="Top" Width="137" Foreground="#FFFFEBEB">
            <TextBox.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Black" />
                    <GradientStop Color="#FFDC9090" Offset="1" />
                </LinearGradientBrush>
            </TextBox.Background>
        </TextBox>
        <TextBox x:Name="Agent2Name" HorizontalAlignment="Left" Height="20" Margin="92,109,0,0" TextWrapping="Wrap"
                 Text="TextBox" VerticalAlignment="Top" Width="137" Foreground="#FFFFEBEB">
            <TextBox.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Black" />
                    <GradientStop Color="#FFDC9090" Offset="1" />
                </LinearGradientBrush>
            </TextBox.Background>
        </TextBox>
        <TextBlock HorizontalAlignment="Left" Margin="133,60,0,0" TextWrapping="Wrap" Text="Agent Names"
                   VerticalAlignment="Top">
            <TextBlock.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Black" />
                    <GradientStop Color="#FFD06363" Offset="1" />
                    <GradientStop Color="#83DE7070" Offset="0.44" />
                </LinearGradientBrush>
            </TextBlock.Background>
        </TextBlock>
        <local:IndicatorControl x:Name="ModelReady" IsModelReady="{Binding IsModelReady}" Margin="20,20,0,0"
                                VerticalAlignment="Top" HorizontalAlignment="Left" Width="10" Height="10" />


    </Grid>
</UserControl>