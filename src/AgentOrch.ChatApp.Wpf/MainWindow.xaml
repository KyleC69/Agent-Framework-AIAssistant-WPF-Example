<Window x:Class="AgentOrch.ChatApp.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:ai="clr-namespace:Microsoft.Extensions.AI;assembly=Microsoft.Extensions.AI.Abstractions"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:AgentOrch.ChatApp.Wpf.Controls"
        xmlns:local="clr-namespace:AgentOrch.ChatApp.Wpf"
        mc:Ignorable="d" Loaded="Window_Loaded"
        Title="AgentOrch Chat" Height="720" Width="980"
        Background="{DynamicResource App.WindowBackgroundBrush}">


    <Window.Resources>
        <local:BubbleMaxWidthConverter x:Key="BubbleMaxWidthConverter" />

        <CornerRadius x:Key="BubbleRadius">12</CornerRadius>

        <SolidColorBrush x:Key="UserBubbleBrush" Color="{DynamicResource App.AccentColor}" />
        <SolidColorBrush x:Key="AgentBubbleBrush" Color="{DynamicResource App.BubbleAgentColor}" />
        <SolidColorBrush x:Key="SystemBubbleBrush" Color="{DynamicResource App.BubbleSystemColor}" />
        <SolidColorBrush x:Key="BubbleForegroundBrush" Color="{DynamicResource App.BubbleForegroundColor}" />
        <SolidColorBrush x:Key="CodeBubbleBackgroundBrush" Color="{DynamicResource App.WindowBackgroundColor}" />

        <Style x:Key="BubbleBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="{StaticResource BubbleRadius}" />
            <Setter Property="MaxWidth" Value="{Binding ElementName=MessagesList, Path=ActualWidth, Converter={StaticResource BubbleMaxWidthConverter}}" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>

        <DataTemplate x:Key="UserMessageTemplate" DataType="{x:Type ai:ChatMessage}">
            <Grid Margin="8,6">
                <Border
                    Style="{StaticResource BubbleBorderStyle}"
                    Background="{StaticResource UserBubbleBrush}"
                    Padding="8,6">
                    <TextBox
                        Text="{Binding Text}"
                        TextWrapping="Wrap"
                        BorderThickness="0"
                        Background="{StaticResource CodeBubbleBackgroundBrush}"
                        Foreground="{StaticResource BubbleForegroundBrush}"
                        IsReadOnly="True"
                        IsReadOnlyCaretVisible="True" />
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="AgentMessageTemplate" DataType="{x:Type ai:ChatMessage}">
            <Grid Margin="12,6">
                <Border
                    Style="{StaticResource BubbleBorderStyle}"
                    Background="{StaticResource AgentBubbleBrush}"
                    Padding="12,10">
                    <controls:MarkdownTextBlock MarkdownText="{Binding Text}" />
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="SystemMessageTemplate" DataType="{x:Type ai:ChatMessage}">
            <Grid Margin="12,6">
                <Border
                    Style="{StaticResource BubbleBorderStyle}"
                    Background="{StaticResource SystemBubbleBrush}"
                    Padding="12,10"
                    Opacity="0.9">
                    <controls:MarkdownTextBlock MarkdownText="{Binding Text}" />
                </Border>
            </Grid>
        </DataTemplate>

        <Style x:Key="MessageListStyle" TargetType="ListBox">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="False" />
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="False" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource App.SurfaceBrush}" Padding="16,14">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="AgentOrch Chat" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource App.TextPrimaryBrush}" />
                    <TextBlock Text="AI agent communication UI" Opacity="0.75" Foreground="{DynamicResource App.TextPrimaryBrush}" />
                </StackPanel>

                <controls:AIToolUsageIndicators x:Name="ToolIndicators"
                                                DockPanel.Dock="Right"
                                                Margin="16,0,0,0"
                                                IndicatorSize="18"
                                                Background="Transparent" />

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Top"
                            Margin="12,0,0,0" MaxWidth="725">
                    <ToggleButton
                        Content="Orchestrated"
                        Padding="10,6,10,6"
                        Foreground="{DynamicResource App.TextPrimaryBrush}"
                        Background="{DynamicResource App.ControlSurfaceBrush}"
                        BorderBrush="Transparent"
                        VerticalAlignment="Top" Checked="ToggleButton_Checked" Width="90" HorizontalAlignment="Left" />

                    <TextBlock Text="Working…" Foreground="{DynamicResource App.TextPrimaryBrush}" Opacity="0.8" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <ProgressBar Width="90" Height="6" IsIndeterminate="True" Margin="10,0,0,0"
                                 VerticalAlignment="Center">
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Messages -->
        <ListBox x:Name="MessagesList"
                 Grid.Row="1"
                 Style="{StaticResource MessageListStyle}"
                 ItemsSource="{Binding Messages}"
                 SelectionMode="Extended" d:ItemsSource="{d:SampleData ItemCount=5}" Foreground="{DynamicResource App.ListForegroundBrush}" Margin="15,0,15,0" Width="930" Padding="25,0,25,0" Grid.IsSharedSizeScope="True" HorizontalAlignment="Center">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="VerticalContentAlignment" Value="Center" />
                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type ai:ChatMessage}">
                    <ContentControl Content="{Binding}" IsHitTestVisible="True">
                        <ContentControl.Style>
                            <Style TargetType="ContentControl">
                                <Setter Property="ContentTemplate" Value="{StaticResource AgentMessageTemplate}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Role}" Value="User">
                                        <Setter Property="ContentTemplate" Value="{StaticResource UserMessageTemplate}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Role}" Value="System">
                                        <Setter Property="ContentTemplate"
                                                Value="{StaticResource SystemMessageTemplate}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ContentControl.Style>
                    </ContentControl>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Composer -->
        <Border Grid.Row="2" Background="{DynamicResource App.SurfaceBrush}" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
<Border Background="{DynamicResource App.WindowBackgroundBrush}" CornerRadius="{StaticResource BubbleRadius}" Padding="3">
                <TextBox
                    x:Name="MessageTextBox"
                    Grid.Column="0"
                    Text="{Binding UserMessage, UpdateSourceTrigger=PropertyChanged,Mode=TwoWay}"
                    Background="{DynamicResource App.WindowBackgroundBrush}"
                    Foreground="{DynamicResource App.TextPrimaryBrush}"
                    BorderBrush="{DynamicResource App.ControlSurfaceBrush}"
                    Padding="12,10"
                    FontSize="14"
                    MinHeight="40"
                    
                    VerticalContentAlignment="Center" AcceptsReturn="True" />
</Border>
                <Button
                    Grid.Column="2"
                    Content="Send"
                    Command="{Binding SendCommand}"
                    IsDefault="True"
                    Padding="16,10"
                    MinHeight="44"
                    Background="{DynamicResource App.AccentBrush}"
                    Foreground="{DynamicResource App.TextPrimaryBrush}"
                    BorderBrush="Transparent" />

                <Button
                    Grid.Column="4"
                    Content="Cancel"
                    Command="{Binding CancelCommand}"
                    Padding="16,10"
                    MinHeight="44"
                    Background="{DynamicResource App.ControlSurfaceBrush}"
                    Foreground="{DynamicResource App.TextPrimaryBrush}"
                    BorderBrush="Transparent">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>