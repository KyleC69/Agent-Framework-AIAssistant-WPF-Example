<Window x:Class="AgentOrchestration.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:ai="clr-namespace:Microsoft.Extensions.AI;assembly=Microsoft.Extensions.AI.Abstractions"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui1="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:controls1="clr-namespace:AgentOrchestration.Wpf.Controls"
        mc:Ignorable="d" Loaded="Window_Loaded"
        Title="Agent Framework Example Chat" Height="800" Width="1200"
        Background="{DynamicResource App.WindowBackgroundBrush}">


    <Window.Resources>
        <controls1:BubbleMaxWidthConverter x:Key="BubbleMaxWidthConverter" />

        <CornerRadius x:Key="BubbleRadius">12</CornerRadius>



        <Style x:Key="BubbleBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="{StaticResource BubbleRadius}" />
            <Setter Property="MaxWidth"
                    Value="{Binding ElementName=MessagesList, Path=ActualWidth, Converter={StaticResource BubbleMaxWidthConverter}}" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>

        <DataTemplate x:Key="UserMessageTemplate" DataType="{x:Type ai:ChatMessage}">
            <Grid Margin="8,6">
                <Border
                    Style="{StaticResource BubbleBorderStyle}"
                    Background="{StaticResource UserBubbleBrush}"
                    Padding="8,6">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Label Content="User: " FontSize="10" HorizontalAlignment="Left" Margin="4,0,0,0" Foreground="{StaticResource BubbleForegroundBrush}" />
                        <TextBox
                        Text="{Binding Text}"
                        TextWrapping="Wrap"
                        BorderThickness="0"
                        Background="{StaticResource CodeBubbleBackgroundBrush}"
                        Foreground="{StaticResource CodeBubbleForegroundBrush}"
                        IsReadOnly="True"
                        IsReadOnlyCaretVisible="True" />
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="AgentMessageTemplate" DataType="{x:Type ai:ChatMessage}">
            <Grid Margin="12,6">
                <Border
                    Style="{StaticResource BubbleBorderStyle}"
                    Background="{StaticResource App.BubbleSystemBrush}"
                    Padding="12,10">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Label Content="Agent" FontSize="10" HorizontalAlignment="Left" Margin="4,0,0,0" Foreground="{StaticResource BubbleForegroundBrush}" />
                        <controls1:MarkdownTextBlock MarkdownText="{Binding Text}" Foreground="#FF120552" Background="{DynamicResource {x:Static SystemColors.ControlDarkDarkBrushKey}}"  />
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="ToolMessageTemplate" DataType="{x:Type ai:ChatMessage}">
            <Grid Margin="12,6">
                <Border
                    Style="{StaticResource BubbleBorderStyle}"
                    Background="{StaticResource App.BubbleSystemBrush}"
                    Padding="12,10">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Label Content="Tool" FontSize="10" HorizontalAlignment="Left" Margin="4,0,0,0" Foreground="{StaticResource BubbleForegroundBrush}" />
                        <controls1:MarkdownTextBlock MarkdownText="{Binding Text}" Foreground="#FF120552" Background="{DynamicResource {x:Static SystemColors.ControlDarkDarkBrushKey}}"  />
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>



        <DataTemplate x:Key="SystemMessageTemplate" DataType="{x:Type ai:ChatMessage}">
            <Grid Margin="12,6">
                <Border
                    Style="{StaticResource BubbleBorderStyle}"
                    Background="{StaticResource SystemBubbleBrush}"
                    Padding="12,10"
                    Opacity="0.9">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Label Content="System" FontSize="10" HorizontalAlignment="Left" Margin="4,0,0,0" Foreground="{StaticResource BubbleForegroundBrush}" />
                        <controls1:MarkdownTextBlock MarkdownText="{Binding Text}" />
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

        <Style x:Key="MessageListStyle" TargetType="ListBox">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="False" />
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="False" />
        </Style>
    </Window.Resources>

    <Grid Background="{DynamicResource App.SurfaceBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="1200" />
        </Grid.ColumnDefinitions>
        <!-- Header -->

        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="{DynamicResource App.SurfaceBrush}" Padding="2,19">
            <DockPanel Background="{DynamicResource App.ControlSurfaceBrush}">
                <StackPanel DockPanel.Dock="Left" Width="500">
                    <TextBlock Text="MS Agent Framework WPF Example Chat" FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource App.HeaderTextPrimaryBrush}" />
                    <TextBlock Text="AI agent communication UI" Opacity="0.95"
                               Foreground="{DynamicResource App.HeaderTextPrimaryBrush}" />
                </StackPanel>


                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Top"
                            Margin="12,0,0,0" MaxWidth="725">
                    <ToggleButton
                        Content="Orchestrated"
                        Padding="10,6,10,6"
                        Foreground="{DynamicResource App.HeaderTextPrimaryBrush}"
                        Background="{DynamicResource App.ControlSurfaceBrush}"
                        BorderBrush="Transparent"
                        VerticalAlignment="Top" Checked="ToggleButton_Checked" Width="90" HorizontalAlignment="Left" />

                    <TextBlock Text="Working…" Foreground="{DynamicResource App.TextPrimaryBrush}" Opacity="0.8"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <ProgressBar Width="90" Height="6" IsIndeterminate="True" Margin="10,0,0,0"
                                 VerticalAlignment="Center">
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Messages -->
        <ListBox x:Name="MessagesList"
                 Grid.Row="1"
                 Style="{StaticResource MessageListStyle}"
                 ItemsSource="{Binding Messages}"
                 SelectionMode="Extended" d:ItemsSource="{d:SampleData ItemCount=5}"
                 Foreground="{DynamicResource App.ListForegroundBrush}" Width="1000" Padding="25,0,25,0"
                 Grid.IsSharedSizeScope="True" HorizontalAlignment="Left" Margin="228,0,0,0" Grid.ColumnSpan="2">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="VerticalContentAlignment" Value="Center" />
                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type ai:ChatMessage}">
                    <ContentControl Content="{Binding}" IsHitTestVisible="True">
                        <ContentControl.Style>
                            <Style TargetType="ContentControl">
                                <Setter Property="ContentTemplate" Value="{StaticResource AgentMessageTemplate}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Role}" Value="User">
                                        <Setter Property="ContentTemplate" Value="{StaticResource UserMessageTemplate}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Role}" Value="System">
                                        <Setter Property="ContentTemplate" Value="{StaticResource SystemMessageTemplate}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Role}" Value="Tool">
                                        <Setter Property="ContentTemplate" Value="{StaticResource ToolMessageTemplate}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ContentControl.Style>
                    </ContentControl>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>


        <Border Grid.Row="2" Name="TextboxWrapper" Grid.ColumnSpan="2" BorderThickness="1" CornerRadius="15" Background="{DynamicResource App.SurfaceBrush}"
                Padding="8,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Name="InnerBorder" 
                        CornerRadius="{StaticResource BubbleRadius}"
                        BorderThickness="6"
                        BorderBrush="{DynamicResource App.BubbleAgentBrush}">


                    <TextBox
                        x:Name="MessageTextBox"
                        
                        Text="{Binding UserMessage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Background="{DynamicResource App.BubbleAgentBrush}"
                        Foreground="{DynamicResource App.BubbleForegroundBrush}"
                        Padding="10,10"
                        FontSize="14"
                        MinHeight="40"
                        BorderThickness="0"
                        VerticalContentAlignment="Center" AcceptsReturn="True" />
                </Border>
                <ui1:Button
                    Grid.Column="5"
                    Appearance="Primary"
                    Content="Send"
                    
                Command="{Binding SendCommand}"
                IsDefault="True"
                Padding="20,10"
                MinHeight="44"
                Background="{DynamicResource App.BubbleAgentBrush}"
                Foreground="{DynamicResource App.BubbleForegroundBrush}"
                BorderBrush="Transparent" />

                <ui1:Button
                    Grid.Column="4"
                    Content="Cancel"
                    Command="{Binding CancelCommand}"
                    Padding="16,10"
                    MinHeight="44"
                    Background="{DynamicResource App.ControlSurfaceBrush}"
                    Foreground="{DynamicResource App.TextPrimaryBrush}"
                    BorderBrush="Transparent">
                    <ui1:Button.Style>
                        <Style TargetType="{x:Type Button}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui1:Button.Style>
                </ui1:Button>
            </Grid>
        </Border>

        <!-- Composer -->
    </Grid>
</Window>